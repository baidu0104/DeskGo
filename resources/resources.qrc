<RCC>
    <qresource prefix="/">
        <file>styles/style.qss</file>
    </qresource>
    <qresource prefix="/icons">
        <file alias="app.ico">icons/app.ico</file>
        <file alias="app.png">icons/app.png</file>
    </qresource>
    <qresource prefix="/i18n">
        <file alias="deskgo_zh_CN.qm">../i18n/deskgo_zh_CN.qm</file>
        <file alias="deskgo_en_US.qm">../i18n/deskgo_en_US.qm</file>
    </qresource>
</RCC>
